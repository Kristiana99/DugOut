<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" 
 "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.dugout.user.mapper.UserMapper">
	<select id="getUserList">
		SELECT 	
	    USERID    
	    ,PASSWORD  
	    ,USERNAME  
	    ,EMAIL
			,ROLE
	    ,REGDATE 
		FROM
			MEMBER
		ORDER BY
			USERID ASC
	</select>
	
	<select id="getIdDupCheck"
		parameterType="string"
		resultType="com.dugout.user.dto.UserDTO">
			SELECT *
			FROM 
				MEMBER
			WHERE 
				USERID = #{userId}
	</select>
	
	<insert id="insertUser">
	INSERT INTO MEMBER 
    (
	    USERID    
	    ,PASSWORD  
	    ,USERNAME  
	    ,EMAIL     
	    ,REGDATE   
    )
    VALUES
    (
	    #{userId}
	    ,#{password}
	    ,#{userName}
	    ,#{email}
	    ,SYSDATE
    )    
	</insert>
	<select id="getUser">
		SELECT 
			 USERID    
	    ,PASSWORD  
	    ,USERNAME  
	    ,EMAIL     
	    ,REGDATE 
	  FROM
	  	MEMBER
	  WHERE
	  	USERID = #{userId}
	</select>
	<update id="updateUser">
		UPDATE 
			MEMBER
		SET
	     PASSWORD  = #{password} 
	    ,USERNAME  = #{userName} 
	    ,EMAIL		 = #{email} 
	 	WHERE
	 		USERID = #{userId}
	 	AND
	 		PASSWORD = #{password}
	</update>
	<delete id="deleteUser">
		DELETE FROM MEMBER
		WHERE	
			USERID = #{userId}
	</delete>
</mapper>